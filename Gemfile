source "https://rubygems.org"

# Required for Ruby 3.4+
gem "csv"
gem "base64"
gem "bigdecimal"

# Jekyll 4.x for Ruby 4.0 compatibility
gem "jekyll", "~> 4.3"

# GitHub Pages dependencies (without the github-pages gem which pins old versions)
gem "jekyll-paginate"
gem "jekyll-gist"
gem "jekyll-redirect-from"
gem "faraday-retry"

gem "wdm", "~> 0.1.0" if Gem.win_platform?

# Plugins
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
end
